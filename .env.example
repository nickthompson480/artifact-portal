# Copy this file to ~/.artifact-portal/.env (the data directory, not the repo root)
# The server reads it on startup.

# Server port
PORT=3000

# JWT signing secret — set this explicitly in production.
# If absent, the server generates one and stores it in ~/.artifact-portal/.env automatically.
# JWT_SECRET=change-me-to-a-long-random-string

# Override data directory paths (rarely needed)
# DB_PATH=~/.artifact-portal/db.sqlite
# FILES_DIR=~/.artifact-portal/files
